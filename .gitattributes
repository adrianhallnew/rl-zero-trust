# Normalize line endings to LF on checkout
* text=auto eol=lf

# Explicit text files
*.py      text eol=lf
*.sh      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.ipynb   text eol=lf

# Dockerfiles (no extension)
Dockerfile  text eol=lf

# GitHub Linguist — language stats
*.ipynb     linguist-detectable=false
*.sh        linguist-detectable=true
*.yaml      linguist-detectable=true
*.yml       linguist-detectable=true
Dockerfile  linguist-detectable=true
